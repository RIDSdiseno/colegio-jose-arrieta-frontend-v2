# Supabase — obtén estos valores en https://supabase.com > tu proyecto > Settings > API
#VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
#VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Tag Manager — obtén el ID en https://tagmanager.google.com
# Formato: GTM-XXXXXXX
VITE_GTM_ID=GTM-XXXXXXX

# Meta Pixel — obtén el ID en https://business.facebook.com > Events Manager
# Formato: número de 16 dígitos
VITE_META_PIXEL_ID=XXXXXXXXXXXXXXXX
